# =============================================
# Render Backend Environment Variables
# =============================================
# Set ALL of these in your Render backend service → Environment → Add Environment Variable

# MongoDB Atlas connection string
MONGODB_URI=mongodb+srv://<user>:<password>@cluster.mongodb.net/<dbname>?retryWrites=true&w=majority

# Session secret (use a long random string in production)
SESSION_SECRET=change-me-to-a-long-random-secret

# Your Render FRONTEND URL (no trailing slash) — used for CORS
FRONTEND_URL=https://your-frontend-service.onrender.com

# Must be set to 'production' so secure cookies and proxy trust are enabled
NODE_ENV=production
